# --- Solana ---
# Path to operator keypair JSON (64-byte array, Solana CLI format).
OPERATOR_KEYPAIR_PATH=/Users/you/.config/solana/operator.json

# Devnet (or testnet/mainnet) RPC URL. WebSocket URL is derived by replacing
# the scheme (http -> ws, https -> wss).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Devnet USDC mint address.
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- polis program IDs ---
# These must be set to the deployed devnet program IDs of the 5 polis programs.
# At time of writing, the on-chain programs are stubbed; replace with real IDs
# after deployment.
POLIS_IDENTITY_PROGRAM_ID=11111111111111111111111111111111
POLIS_WALLET_PROGRAM_ID=11111111111111111111111111111111
POLIS_X402_PROGRAM_ID=11111111111111111111111111111111
POLIS_CREDIT_PROGRAM_ID=11111111111111111111111111111111
POLIS_REPUTATION_PROGRAM_ID=11111111111111111111111111111111

# --- LLM (OpenAI-compatible endpoint) ---
# Free NVIDIA API catalog key (https://build.nvidia.com -> "Get API Key").
NVIDIA_API_KEY=nvapi-...
# Optional: override the endpoint for any other OpenAI-compatible provider
# (OpenAI, Together, local vLLM, ...). Defaults to NVIDIA's catalog.
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional aliases if not using NVIDIA: LLM_API_KEY / OPENAI_API_KEY.

# --- Agent config ---
# Price per /summarize call, in US dollars. Default $0.10 per spec.
SERVICE_PRICE_USD=0.10

# Open model used for summarization (NVIDIA free tier). Fast + free.
LLM_MODEL=meta/llama-3.1-8b-instruct

# Trigger auto-borrow when wallet balance drops below this many USD.
LOW_BALANCE_THRESHOLD_USD=5

# How much to draw on each auto-borrow event, in USD. Spec example: $10.
AUTO_BORROW_AMOUNT_USD=10

# Daily repayment uses this fraction of yesterday's earnings.
DAILY_REPAY_FRACTION=0.5

# How long the agent will accept a PaymentReceived event as proof (seconds).
PAYMENT_VALIDITY_WINDOW_SECONDS=300

# Server binding.
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Development convenience: skip on-chain payment verification on /summarize.
# Logs a warning each time. NEVER set this in production.
DEV_MODE=false
